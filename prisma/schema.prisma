generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model AuditEvent {
  id           String   @id @default(cuid())
  timestamp    DateTime
  actor        String
  actorType    String
  action       String
  resource     String
  resourceType String
  ipAddress    String
  location     String?
  userAgent    String?
  severity     String
  status       String
  outcome      String
  riskScore    Int
  flagged      Boolean  @default(false)
  reason       String?
  metadata     String?
  createdAt    DateTime @default(now())

  notes AnalystNote[]

  @@index([timestamp])
  @@index([actor])
  @@index([action])
  @@index([severity])
  @@index([flagged])
}

model AnalystNote {
  id        String   @id @default(cuid())
  eventId   String
  content   String
  author    String
  createdAt DateTime @default(now())

  event AuditEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model AlertCase {
  id            String   @id @default(cuid())
  alertKey      String   @unique
  title         String
  actor         String
  detectionType String
  status        String
  owner         String?
  disposition   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  alertKey  String
  type      String   // alert_created, alert_escalated, alert_resolved
  title     String
  message   String
  severity  String   // low, medium, high, critical
  recipients String  // JSON array of email addresses
  channels  String   // JSON array of channels: email, slack, webhook, sms
  metadata  String?  // JSON metadata
  sentAt    DateTime @default(now())
  status    String   @default("sent") // sent, failed, pending

  @@index([alertKey])
  @@index([sentAt])
}
